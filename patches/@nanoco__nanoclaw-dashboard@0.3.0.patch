@@ -0,0 +1,86 @@
+import { layout } from '../layout.js';
+export function skillsPage() {
+    return layout('Skills', '/dashboard/skills', `
+    <h2 class="page-title">Skills</h2>
+    <div id="content"><div class="loading">Loading...</div></div>
+    <script>
+    (async () => {
+      try {
+        const [skills, agentGroups] = await Promise.all([
+          api('/api/skills'),
+          api('/api/agent-groups'),
+        ]);
+
+        if (!skills || skills.length === 0) {
+          document.getElementById('content').innerHTML = '<div class="loading">No skills installed</div>';
+          return;
+        }
+
+        const agentSkillsList = skills.filter(s => s.type === 'agent');
+        const container = skills.filter(s => s.type === 'container');
+        const host = skills.filter(s => s.type === 'host');
+
+        // Build a map of agent skill name → groups that have it assigned
+        const skillGroups = {};
+        for (const g of (agentGroups || [])) {
+          for (const skillName of (g.agentSkills || [])) {
+            if (!skillGroups[skillName]) skillGroups[skillName] = [];
+            skillGroups[skillName].push(g.name || g.id);
+          }
+        }
+
+        let html = '';
+
+        if (agentSkillsList.length > 0) {
+          html += '<h3 class="section-title">Agent Skills (' + agentSkillsList.length + ')</h3>';
+          html += '<table><tr><th>Name</th><th>Description</th><th>Assigned To</th></tr>';
+          for (const s of agentSkillsList) {
+            const groups = skillGroups[s.name] || [];
+            const groupsHtml = groups.length > 0
+              ? groups.map(g => '<span class="badge badge-blue">' + esc(g) + '</span>').join(' ')
+              : '<span style="color:#555">none</span>';
+            html += '<tr>' +
+              '<td><code style="font-family:monospace;font-size:12px;color:#4ade80">/' + esc(s.name) + '</code></td>' +
+              '<td style="color:#ccc">' + esc(s.description || '—') + '</td>' +
+              '<td>' + groupsHtml + '</td>' +
+              '</tr>';
+          }
+          html += '</table>';
+        }
+
+        if (container.length > 0) {
+          html += '<h3 class="section-title">Container Skills (' + container.length + ')</h3>';
+          html += '<table><tr><th>Name</th><th>Description</th></tr>';
+          for (const s of container) {
+            html += '<tr>' +
+              '<td><code style="font-family:monospace;font-size:12px;color:#c084fc">/' + esc(s.name) + '</code></td>' +
+              '<td style="color:#ccc">' + esc(s.description || '—') + '</td>' +
+              '</tr>';
+          }
+          html += '</table>';
+        }
+
+        if (host.length > 0) {
+          html += '<h3 class="section-title">Host Skills (' + host.length + ')</h3>';
+          html += '<table><tr><th>Name</th><th>Description</th></tr>';
+          for (const s of host) {
+            html += '<tr>' +
+              '<td><code style="font-family:monospace;font-size:12px;color:#7eb8da">/' + esc(s.name) + '</code></td>' +
+              '<td style="color:#ccc">' + esc(s.description || '—') + '</td>' +
+              '</tr>';
+          }
+          html += '</table>';
+        }
+
+        if (!html) {
+          html = '<div class="loading">No skills installed</div>';
+        }
+
+        document.getElementById('content').innerHTML = html;
+      } catch (e) {
+        document.getElementById('content').innerHTML = '<div class="loading">Error: ' + esc(e.message) + '</div>';
+      }
+    })();
+    </script>
+  `);
+}
